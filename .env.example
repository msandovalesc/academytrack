# Copy to .env for local scripts (migrate/seed) run outside `netlify dev`.
# `netlify dev` and deployed functions get these from the Netlify environment automatically.

# Provisioned by `netlify db init` (Neon Postgres connection string).
NETLIFY_DATABASE_URL=

# Secret used to sign login session JWTs. Generate a long random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Credentials for the initial admin user created by db/seed.mjs.
SEED_ADMIN_EMAIL=admin@academytrack.local
SEED_ADMIN_PASSWORD=change-me-now
SEED_ADMIN_NAME=Admin
